NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Wix (legacy, can be removed once Mailchimp + Stripe are set up)
VITE_WIX_CHECKOUT_URL=https://your-wix-site.com/product-or-checkout
VITE_WIX_CONTACT_URL=https://your-wix-site.com/contact-or-form

# Mailchimp embedded form action URL
# Find it in: Mailchimp > Audience > Signup forms > Embedded forms > copy the form action URL
VITE_MAILCHIMP_ACTION_URL=https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx

# Stripe Payment Link URL (for the deposit / pre-order button)
# Create one at: https://dashboard.stripe.com/payment-links
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxx
